@model VASReportingTool.Models.ForgotPasswordViewModel
@{
    Layout = null;
    ViewBag.Title = "Forgot Password";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/site.css?v=20260326-2")" />
</head>
<body>
    <div class="auth-shell otp-shell">
        <section class="auth-panel auth-panel-form auth-panel-form-wide">
            <div class="auth-form-top">Password Recovery</div>
            <h2>Reset your password</h2>
            <p class="muted">Enter your username or email. If the account exists, we will send a reset link.</p>
            @if (!string.IsNullOrWhiteSpace(Model.InfoMessage))
            {
                <div class="info-banner">@Model.InfoMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="error">@Model.ErrorMessage</div>
            }
            <form action="@Url.Content("~/Account/ForgotPassword")" method="post">
                @Html.AntiForgeryToken()
                <div class="field"><label>Username Or Email</label>@Html.TextBoxFor(m => m.UsernameOrEmail, new { placeholder = "name@example.com or username" })</div>
                <button class="primary-btn auth-submit" type="submit">Send Reset Link</button>
            </form>
            <div class="auth-links">
                <a href="@Url.Action("Login", "Account")">Back to login</a>
            </div>
        </section>
    </div>
</body>
</html>

