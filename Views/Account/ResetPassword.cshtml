@model VASReportingTool.Models.ResetPasswordViewModel
@{
    Layout = null;
    ViewBag.Title = "Reset Password";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/site.css?v=20260326-2")" />
</head>
<body>
    <div class="auth-shell otp-shell">
        <section class="auth-panel auth-panel-form auth-panel-form-wide">
            <div class="auth-form-top">Password Recovery</div>
            <h2>Create a new password</h2>
            <p class="muted">Choose a strong new password for your reporting account.</p>
            @if (!string.IsNullOrWhiteSpace(Model.InfoMessage))
            {
                <div class="info-banner">@Model.InfoMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="error">@Model.ErrorMessage</div>
            }
            <form action="@Url.Content("~/Account/ResetPassword")" method="post">
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Token)
                <div class="field"><label>New Password</label>@Html.PasswordFor(m => m.NewPassword, new { placeholder = "Enter new password" })</div>
                <div class="field"><label>Confirm Password</label>@Html.PasswordFor(m => m.ConfirmPassword, new { placeholder = "Re-enter new password" })</div>
                <button class="primary-btn auth-submit" type="submit">Reset Password</button>
            </form>
            <div class="auth-links">
                <a href="@Url.Action("Login", "Account")">Back to login</a>
            </div>
        </section>
    </div>
</body>
</html>

